# ============================================================
# ONG CHADIA — Back-end — Variables d'environnement
# ============================================================
# Copie ce fichier en .env et remplis les valeurs
# cp .env.example .env

# ---- Base de donnees (Railway PostgreSQL) ----
DATABASE_URL="postgresql://user:password@host:5432/chadia_db"

# ---- NextAuth ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # Genere avec : openssl rand -base64 32

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Resend (Emails) ----
RESEND_API_KEY=""
CONTACT_EMAIL_GENERAL="chadiaong@gmail.com"
CONTACT_EMAIL_PARTENARIAT="chadiaong@gmail.com"

# ---- Super Admin initial (utilise par le seed) ----
SUPER_ADMIN_EMAIL=""
SUPER_ADMIN_PASSWORD=""

# ---- CORS (origines autorisees, separees par des virgules) ----
ALLOWED_ORIGINS="https://ong-chadia.com,https://www.ong-chadia.com"

# ---- URL du front public (pour les liens dans les emails) ----
FRONTEND_URL="https://ong-chadia.com"
